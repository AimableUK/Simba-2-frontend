  "about": {
    "hero": {
      "eyebrow": "Wasifu wa Kampuni",
      "title_line1": "Kuhusu Simba",
      "title_line2": "Supermarket",
      "subtitle": "Supermarket inayoheshimika zaidi Rwanda — ushuhuda wa mafanikio ya kiuchumi ya nchi, ikitoa mahitaji ya kila siku ya Kigali na zaidi tangu 2008."
    },
    "origin": {
      "eyebrow": "Historia ya Asili",
      "heading": "Hapo Ndipo Ilipoanza",
      "paragraph1": "SIMBA SUPERMARKET LTD ilianzishwa mnamo <strong>3 Desemba 2007</strong> kama Kampuni ya Dhima Ndogo na lengo wazi: kuwa duka kubwa zaidi la rejareja katika eneo hili. Ilianzishwa na <strong>Bw. Teklay Teame</strong> na washirika wake, kampuni inaagiza bidhaa kutoka Ulaya, Misri, Dubai, China, Uturuki na zaidi kuhakikisha aina mbalimbali za bidhaa.",
      "paragraph2": "Uzinduzi rasmi mnamo <strong>8 Agosti 2008</strong> uliunda zaidi ya <strong>kazi 450</strong> kwa wananchi wa Rwanda. Na matawi 11 kote Rwanda, Simba inatoa uzoefu wa ununuzi wa kila kitu — butchery, bakery, cafe na zaidi — ikihudumia mashirika ya kimataifa, NGO za ndani, makampuni ya kibinafsi na wizara za serikali."
    },
    "values": {
      "eyebrow": "Imani & Maadili",
      "heading": "Tunachosimamia",
      "items": {
        "respect": {
          "title": "Heshima kwa Mtu Binafsi",
          "body": "Sisi ni watu wa kawaida wanaofanya kazi kwa bidii waliojumuika kukamilisha mambo ya ajabu. Tunashauriana kwa heshima na kuhamasisha kila mtu kutoa mawazo yao — hivi ndivyo tunavyoonyesha heshima."
        },
        "service": {
          "title": "Huduma kwa Wateja",
          "body": "Wateja wetu ndio sababu ya biashara yetu. Tunatoa bidhaa bora kwa bei nafuu zaidi na huduma bora ya wateja inayowezekana, ikitafuta daima kuzidi matarajio."
        },
        "excellence": {
          "title": "Kujitahidi kwa Ubora",
          "body": "Tunajivunia mafanikio yetu lakini hatujaridhika kamwe. Tunaendelea kutafuta zaidi kuleta mawazo na malengo mapya maishani — Je, hii ndiyo bora ninayoweza kufanya? Swali hilo linasukuma kila kitu."
        }
      }
    },
